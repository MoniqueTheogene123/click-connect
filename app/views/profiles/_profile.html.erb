
<div class="card" style="width: 18rem;">
    <img src="<%= user.profile_image_url %>" class="card-img-top" alt="profile image for <%= user.full_name %>" height="175px">
  <div class="card-body">
    <h5 class="card-title"><%= user.full_name %></h5>
    <p class="card-text"><%= user.bio %></p>
  </div>
  <ul class="list-group list-group-flush">
    <li class="list-group-item"><%= user.full_name %>'s Skills:</li>
    <% user.skills.each do |skill| %>
      <li class="list-group-item"><%= skill.name.titleize %></li>
    <% end %>
  </ul>
  <div class="card-body">
    <%= link_to "View Profile", profile_path(user), class: "card-link" %>
  </div>
</div>
